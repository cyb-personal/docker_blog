<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.comment.mapper.CommentMapper">

    <resultMap id="BaseMap" type="com.blog.comment.entity.Comment">
        <id column="id" property="id" />
        <result column="post_id" property="postId" />
        <result column="user_id" property="userId" />
        <result column="content" property="content" />
        <result column="create_time" property="createTime" />
        <result column="author_name" property="authorName" />
        <result column="author_avatar" property="authorAvatar" />
    </resultMap>

    <select id="findById" resultMap="BaseMap">
        SELECT c.*, u.nickname AS author_name, u.avatar AS author_avatar
        FROM `comment` c
        LEFT JOIN `user` u ON c.user_id = u.id
        WHERE c.id = #{id}
    </select>

    <select id="findByPostId" resultMap="BaseMap">
        SELECT c.*, u.nickname AS author_name, u.avatar AS author_avatar
        FROM `comment` c
        LEFT JOIN `user` u ON c.user_id = u.id
        WHERE c.post_id = #{postId}
        ORDER BY c.create_time ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `comment` (post_id, user_id, content, create_time)
        VALUES (#{postId}, #{userId}, #{content}, #{createTime})
    </insert>

    <delete id="deleteById">
        DELETE FROM `comment` WHERE id = #{id}
    </delete>

    <select id="countByPostId" resultType="int">
        SELECT COUNT(*) FROM `comment` WHERE post_id = #{postId}
    </select>

</mapper>
